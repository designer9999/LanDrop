{
  "productName": "LanDrop",
  "version": "1.0.0",
  "identifier": "com.landrop.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LanDrop",
        "width": 520,
        "height": 720,
        "minWidth": 420,
        "minHeight": 550,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "/storage/**", "$DOWNLOAD/**"]
      }
    }
  },
  "plugins": {
    "shell": { "open": true },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5QzBCOUY4QjZDNTg0MUEKUldRYWhNVzIrTG5BeWR1L3l0S2JuNHZ3a1UrNXNPcmpLUEtTcU5Ic2Z0eE80ZUhWUnNyTWdjVnIK",
      "endpoints": [
        "https://github.com/designer9999/Crude/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
